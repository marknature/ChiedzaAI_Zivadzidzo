{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zivadzidzo.chiedza.ai/schemas/teacher_roles.schema.json",
  "title": "Teacher role AI-disruption exposure assessment",
  "description": "A cohort-safe assessment intended to guide professional-development planning, not employment decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["ai_disruption_exposure_score", "exposure_band", "reskilling_priority", "contributing_factors", "recommended_actions", "confidence", "caveats"],
  "properties": {
    "ai_disruption_exposure_score": { "type": "number", "minimum": 0, "maximum": 100, "description": "0-24 low, 25-49 moderate, 50-74 high, 75-100 critical exposure." },
    "exposure_band": { "type": "string", "enum": ["low", "moderate", "high", "critical"], "description": "Must correspond to the score band: 0-24 low, 25-49 moderate, 50-74 high, 75-100 critical." },
    "reskilling_priority": { "type": "string", "enum": ["maintain", "develop", "prioritize", "urgent"], "description": "Maintain maps to low exposure; develop to moderate; prioritize to high; urgent to critical." },
    "contributing_factors": {
      "type": "array", "minItems": 1, "maxItems": 6,
      "items": { "$ref": "#/$defs/factor" }
    },
    "recommended_actions": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "string", "minLength": 8, "maxLength": 280 } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "caveats": { "const": "This output is LLM-reasoned, not a trained model prediction, and is associational rather than causal." }
  },
  "$defs": {
    "factor": {
      "type": "object", "additionalProperties": false,
      "required": ["factor", "direction", "relative_weight", "evidence"],
      "properties": {
        "factor": { "type": "string", "minLength": 2, "maxLength": 100 },
        "direction": { "type": "string", "enum": ["increases_risk", "decreases_risk"] },
        "relative_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": { "type": "string", "minLength": 4, "maxLength": 280 }
      }
    }
  }
}
