{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zivadzidzo.chiedza.ai/schemas/curriculum_skills.schema.json",
  "title": "Curriculum skill relevance assessment",
  "description": "An assessment of curriculum relevance to emerging skills and work practices.",
  "type": "object",
  "additionalProperties": false,
  "required": ["relevance_score", "relevance_band", "emerging_skill_tags", "declining_skill_tags", "contributing_factors", "recommended_actions", "confidence", "caveats"],
  "properties": {
    "relevance_score": { "type": "number", "minimum": 0, "maximum": 100, "description": "0-24 critical, 25-49 high, 50-74 moderate, 75-100 low curriculum-relevance risk." },
    "relevance_band": { "type": "string", "enum": ["low", "moderate", "high", "critical"], "description": "Risk band derived from the score: 75-100 low, 50-74 moderate, 25-49 high, 0-24 critical." },
    "emerging_skill_tags": { "type": "array", "maxItems": 10, "items": { "type": "string", "minLength": 2, "maxLength": 80 }, "uniqueItems": true },
    "declining_skill_tags": { "type": "array", "maxItems": 10, "items": { "type": "string", "minLength": 2, "maxLength": 80 }, "uniqueItems": true },
    "contributing_factors": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "$ref": "#/$defs/factor" } },
    "recommended_actions": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "string", "minLength": 8, "maxLength": 280 } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "caveats": { "const": "This output is LLM-reasoned, not a trained model prediction, and is associational rather than causal." }
  },
  "$defs": {
    "factor": {
      "type": "object", "additionalProperties": false,
      "required": ["factor", "direction", "relative_weight", "evidence"],
      "properties": {
        "factor": { "type": "string", "minLength": 2, "maxLength": 100 },
        "direction": { "type": "string", "enum": ["increases_risk", "decreases_risk"] },
        "relative_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": { "type": "string", "minLength": 4, "maxLength": 280 }
      }
    }
  }
}
